# ─── Required ───────────────────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# SQLite (default, zero setup). Swap to PostgreSQL URL for production:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tales360
DATABASE_URL=sqlite+aiosqlite:///./360tales.db

# ─── Optional — TTS (falls back to free gTTS if not set) ─────────────────────
ELEVENLABS_API_KEY=

# ─── Optional — AI Depth Maps (falls back to PIL if not set) ─────────────────
REPLICATE_API_KEY=

# ─── Optional — Cloud Storage (falls back to local disk if not set) ──────────
CLOUDINARY_URL=

# ─── CORS origins ────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
