# ─── Required ───────────────────────────────────────────────────────────────
# Generate a strong random key:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Free cluster at: https://www.mongodb.com/cloud/atlas
# Replace YOUR_USERNAME, YOUR_PASSWORD, YOUR_CLUSTER with your actual values
MONGODB_URL=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?appName=Cluster0
DB_NAME=horizon

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/
# 2. APIs & Services → Credentials → Create OAuth 2.0 Client ID (Web application)
# 3. Add http://localhost:5173 to Authorized JavaScript origins
# 4. Paste the Client ID below
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# ─── Optional — TTS (falls back to free gTTS if not set) ─────────────────────
# Get your key at: https://elevenlabs.io/
ELEVENLABS_API_KEY=

# ─── Optional — AI Depth Maps (falls back to PIL if not set) ─────────────────
# Get your key at: https://replicate.com/
REPLICATE_API_KEY=

# ─── Optional — AI Image Description (falls back to template if not set) ──────
# Get your free key at: https://aistudio.google.com/
GEMINI_API_KEY=

# ─── Optional — Cloud Storage (falls back to local disk if not set) ──────────
# Get your URL at: https://cloudinary.com/
CLOUDINARY_URL=

# ─── CORS origins ────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Base URL for file serving ────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000
