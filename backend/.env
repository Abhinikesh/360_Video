# ─── Required ───────────────────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=horizon-dev-secret-key-change-in-production

# ─── MongoDB ─────────────────────────────────────────────────────────────────
# Get a free cluster at mongodb.com/cloud/atlas
MONGODB_URL=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?retryWrites=true&w=majority
DB_NAME=horizon

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# See instructions in .env.example to get your free Client ID
GOOGLE_CLIENT_ID=your_google_client_id_here

# ─── Optional — TTS (falls back to free gTTS if not set) ─────────────────────
ELEVENLABS_API_KEY=

# ─── Optional — AI Depth Maps (falls back to PIL if not set) ─────────────────
REPLICATE_API_KEY=

# ─── Optional — Cloud Storage (falls back to local disk if not set) ──────────
CLOUDINARY_URL=

# ─── CORS origins ────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Base URL for file serving ───────────────────────────────────────────────
API_BASE_URL=http://localhost:8000
